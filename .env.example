# Copy to .env.local for local dev (see README.md's note on escaping `$`
# in ADMIN_PASSWORD_HASH), or set these directly in the Vercel dashboard.

NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=

SESSION_ENC_KEY=
INTERNAL_FN_SECRET=

# Optional: enables "Continue with Google" on the login page.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: restrict every login (including Google) to this one address.
OWNER_EMAIL=
